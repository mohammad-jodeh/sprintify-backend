# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sprintify
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Node Environment
NODE_ENV=production

# Server Configuration
PORT=4000
API_PREFIX=/api/v1

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_change_this_in_production_min_32_chars
JWT_EXPIRY=24h

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Email Service (Optional)
POSTMARK_API_TOKEN=your_postmark_token_here

# Logging
LOG_LEVEL=info
