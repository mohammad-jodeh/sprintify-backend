# ===================================================================
# SPRINTIFY BACKEND - ENVIRONMENT VARIABLES
# ===================================================================
# IMPORTANT: Copy this file to .env and fill in values
# For Railway: Most variables are auto-set. Only fill: JWT_SECRET, SendGrid/Postmark

# ===================================================================
# DATABASE - Railway PostgreSQL (AUTO-PROVIDED)
# ===================================================================
# Railway creates this automatically when you add PostgreSQL service
# Copy from Railway Dashboard → PostgreSQL service → Variables
# Example: postgresql://user:token@host:5432/railway
DATABASE_URL=postgresql://user:password@host:5432/sprintify

# ===================================================================
# NODE ENVIRONMENT
# ===================================================================
# production = Production (Railway)
# development = Local testing
NODE_ENV=production

# ===================================================================
# SERVER CONFIGURATION
# ===================================================================
# Port: Railway automatically assigns 4000
PORT=4000

# API route prefix
API_PREFIX=/api/v1

# ===================================================================
# JWT AUTHENTICATION - REQUIRED FOR PRODUCTION
# ===================================================================
# Generate secure random string:
# - Terminal: openssl rand -hex 32
# - Online: https://generate-random.org/ (32 characters)
# MUST be 32+ characters for security!
JWT_SECRET=your_super_secure_jwt_secret_key_change_this_in_production_min_32_chars

# JWT token expiry
JWT_EXPIRY=24h

# ===================================================================
# FRONTEND CONFIGURATION - CORS
# ===================================================================
# Local development
# FRONTEND_URL=http://localhost:5173

# Production (update with your Vercel domain)
FRONTEND_URL=https://your-app.vercel.app

# ===================================================================
# EMAIL SERVICE - CHOOSE ONE OPTION
# ===================================================================

# OPTION 1: SendGrid (Recommended) ✅
# Get free API key at https://sendgrid.com/free
# Generate API Key in: Settings → API Keys → Create API Key
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourapp.com

# OPTION 2: Postmark (Alternative)
# Get token at https://postmarkapp.com
# Uncomment below and comment out SendGrid above
# POSTMARK_API_TOKEN=your_postmark_token_here
# POSTMARK_FROM_EMAIL=noreply@yourapp.com

# ===================================================================
# LOGGING
# ===================================================================
# Levels: error, warn, info, debug, trace
LOG_LEVEL=info

# ===================================================================
# OPTIONAL: SOCKET.IO (Real-time notifications)
# ===================================================================
SOCKET_IO_ENABLED=true

# ===================================================================
# DEPLOYMENT INSTRUCTIONS
# ===================================================================
# 1. Create .env file (copy this file)
# 2. Fill in:
#    - DATABASE_URL: From Railway PostgreSQL
#    - JWT_SECRET: Generate secure random string
#    - SENDGRID_API_KEY or POSTMARK_TOKEN: From email service
#    - FRONTEND_URL: Your Vercel frontend URL
# 3. DO NOT commit .env to GitHub (it's in .gitignore)
# 4. On Railway, set variables in Variables panel
# 5. Deploy!

# ===================================================================
# RAILWAY.APP SETUP GUIDE
# ===================================================================
# 1. Go to https://railway.app
# 2. Connect your sprintify-backend GitHub repo
# 3. Add PostgreSQL database (Railway auto-creates DATABASE_URL)
# 4. In Railway Variables panel, set these REQUIRED variables:
#    
#    JWT_SECRET            → REQUIRED! Generate: openssl rand -hex 32
#    NODE_ENV              → production
#    FRONTEND_URL          → https://your-app.vercel.app
#
# 5. Optional variables (for email notifications):
#    SENDGRID_API_KEY      → From https://sendgrid.com/free (recommended)
#    SENDGRID_FROM_EMAIL   → noreply@yourdomain.com
#
# 6. NOTE: These are AUTO-PROVIDED by Railway:
#    DATABASE_URL          → Auto-created by PostgreSQL service
#    PORT                  → Auto-assigned (usually 4000)
#
# 7. Save variables and Railway auto-deploys!
# 8. Get your backend URL from Railway → Domains
# 9. Update Vercel VITE_API_BASE_URL with this URL

# ===================================================================
# COMMON ISSUES
# ===================================================================
# Error: "Cannot find module 'dotenv'"
# → Run: npm install
#
# Error: "Database connection refused"
# → Check DATABASE_URL is correct in Railway
#
# Error: "Email not sending"
# → Verify SENDGRID_API_KEY is correct
# → Check email domain is verified in SendGrid
#
# Error: "502 Bad Gateway"
# → Check logs: Railway → Logs tab
# → Restart service if needed

